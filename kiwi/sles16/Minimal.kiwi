    <preferences profiles="s390x-dasd">
        <type image="oem" bootkernel="custom" bootpartition="true" bootpartsize="300" bootfilesystem="ext2" btrfs_quota_groups="true" btrfs_root_is_snapshot="true" bundle_format="%N-Image.%A-%I" filesystem="btrfs" kernelcmdline="dasd_mod.dasd=ipldev hvc_iucv=8 TERM=dumb security=selinux selinux=1 quiet rw" devicepersistency="by-uuid" target_blocksize="4096">
            <bootloader name="grub2_s390x_emu" console="serial" targettype="CDL"/>
            <systemdisk>
                <volume name="boot/grub2/s390x-emu" mountpoint="boot/grub2/s390x-emu"/>
                <volume name="home"/>
                <volume name="root"/>
                <volume name="opt"/>
                <volume name="srv"/>
                <volume name="usr/local"/>
                <volume name="var" copy_on_write="false"/>
            </systemdisk>
            <size unit="G">5</size>
        </type>
        <version>16.0.0</version>
        <packagemanager>zypper</packagemanager>
        <bootloader-theme>SUSE</bootloader-theme>
        <rpm-excludedocs>true</rpm-excludedocs>
    </preferences>
    <preferences profiles="s390x-dasd-Cloud">
        <type image="oem" bootkernel="custom" bootpartition="true" bootpartsize="300" bootfilesystem="ext2" bundle_format="%N-Image.%A-%I" filesystem="xfs" kernelcmdline="dasd_mod.dasd=ipldev hvc_iucv=8 TERM=dumb security=selinux selinux=1 quiet net.ifnames=0 rw" devicepersistency="by-uuid" target_blocksize="4096">
            <bootloader name="grub2_s390x_emu" console="serial" targettype="CDL"/>
            <size unit="G">5</size>
        </type>
        <version>16.0.0</version>
        <packagemanager>zypper</packagemanager>
        <bootloader-theme>SUSE</bootloader-theme>
        <rpm-excludedocs>true</rpm-excludedocs>
    </preferences>
    <preferences profiles="s390x-fcp">
        <version>16.0.0</version>
        <packagemanager>zypper</packagemanager>
        <bootsplash-theme>openSUSE</bootsplash-theme>
        <bootloader-theme>openSUSE</bootloader-theme>
        <rpm-excludedocs>true</rpm-excludedocs>
        <locale>en_US</locale>
        <type
          image="oem"
          filesystem="btrfs"
          installpxe="true"
          bootpartition="true"
          bootpartsize="300"
          bundle_format="%N-Image.%A-%I"
          bootfilesystem="ext4"
          initrd_system="dracut"
          kernelcmdline="hvc_iucv=8 TERM=dumb security=selinux selinux=1 quiet systemd.show_status=1 rw"
          devicepersistency="by-uuid"
          btrfs_root_is_snapshot="true"
          btrfs_quota_groups="true"
        >
            <oemconfig>
                <oem-multipath-scan>true</oem-multipath-scan>
            </oemconfig>
            <bootloader name="grub2_s390x_emu" console="serial" timeout="3" targettype="SCSI"/>
            <systemdisk>
                <volume name="home"/>
                <volume name="root"/>
                <volume name="opt"/>
                <volume name="srv"/>
                <volume name="boot/grub2/s390x-emu" mountpoint="boot/grub2/s390x-emu"/>
                <volume name="usr/local"/>
                <volume name="var" copy_on_write="false"/>
            </systemdisk>
            <size unit="G">5</size>
        </type>
    </preferences>
    <preferences profiles="s390x-fcp-Cloud">
    <type
        image="oem"
        bootkernel="custom"
        bootpartition="true"
        bootpartsize="300"
        bootfilesystem="ext2"
        bundle_format="%N-Image.%A-%I"
        filesystem="xfs"
        kernelcmdline="hvc_iucv=8 TERM=dumb security=selinux selinux=1 quiet net.ifnames=0 rw rd.multipath=1"
        devicepersistency="by-uuid"
    >
        <oemconfig>
            <oem-multipath-scan>true</oem-multipath-scan>
        </oemconfig>
        <bootloader
            name="grub2_s390x_emu"
            console="serial"
            targettype="SCSI"
        />
        <size unit="G">5</size>
    </type>
    <version>16.0.0</version>
    <packagemanager>zypper</packagemanager>
    <bootloader-theme>openSUSE</bootloader-theme>
    <rpm-excludedocs>true</rpm-excludedocs>
</preferences>
    <preferences profiles="ppc64le-4096-raw">
        <version>16.0.0</version>
        <packagemanager>zypper</packagemanager>
        <bootsplash-theme>openSUSE</bootsplash-theme>
        <bootloader-theme>openSUSE</bootloader-theme>
        <rpm-excludedocs>true</rpm-excludedocs>
        <type
            image="oem"
            filesystem="btrfs"
            firmware="ofw"
            bootpartition="false"
            bootkernel="custom"
            devicepersistency="by-uuid"
            btrfs_quota_groups="true"
            btrfs_root_is_snapshot="true"
            target_blocksize="4096"
            bundle_format="%N-VM.%A-%I"
        >
            <systemdisk>
                <volume name="root"/>
                <volume name="home"/>
                <volume name="tmp"/>
                <volume name="opt"/>
                <volume name="srv"/>
                <volume name="boot/grub2/powerpc-ieee1275"/>
                <volume name="usr/local"/>
                <volume name="var" copy_on_write="false"/>
            </systemdisk>
        </type>
    </preferences>
